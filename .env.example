# FinBiz Operator Console — example environment file
#
# There are NO build-time secrets. The app is a static Vite/React site: it reads
# its content from typed modules in src/content/*.ts and builds to dist/. Nothing
# at build or run time needs an API key, token, or hook URL — so a real .env is
# not required to develop or deploy.
#
# (The old n8n Docs->Claude->GitHub sync is retired. Content is now updated by
# hand: the owner updates the FinBiz Master Doc, then hands it to Claude Code,
# which edits src/content/*.ts and commits. See docs/DAILY-UPDATES.md.)

# Reference only — NOT a secret. The single source of truth for all app content.
# A Google Drive doc id; kept here so you don't have to hunt for it.
# Snapshot lives at docs/MASTER-DOC.md.
MASTER_DOC_ID=1D93j3Pjo6HPqdtb6IiAPvb5DIp_cuZl4bU-bsBawexg
