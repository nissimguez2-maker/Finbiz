# FinBiz Operator Console — example environment file
#
# Copy to a real secrets store (n8n credentials, your CI's env, etc.) and fill in.
# DO NOT commit a real .env — it's gitignored. These are PLACEHOLDERS, no real secrets.
#
# The static site itself needs NO build-time secrets. Everything below is for the
# optional daily-update sync (see docs/N8N-SYNC.md) and the redeploy button.

# --- Netlify ----------------------------------------------------------------
# "Sync now / Redeploy" Build Hook. A POST to this URL triggers a fresh build+deploy.
# Create it: Netlify → Site settings → Build & deploy → Build hooks → Add build hook.
# Treat it like a password — anyone with the URL can trigger a deploy.
NETLIFY_BUILD_HOOK_URL=https://api.netlify.com/build_hooks/REPLACE_WITH_YOUR_HOOK_ID

# --- Anthropic (Claude) — used by the n8n sync transform --------------------
# Get one at https://console.anthropic.com → API keys.
# The sync uses model claude-opus-4-8 (recommended) or claude-sonnet-4-6 (cheaper).
ANTHROPIC_API_KEY=sk-ant-REPLACE_WITH_YOUR_KEY

# --- GitHub — used by the n8n sync to commit regenerated src/content/*.ts ---
# Fine-grained Personal Access Token scoped to THIS repo with Contents: Read and write.
# GitHub → Settings → Developer settings → Fine-grained tokens.
GITHUB_TOKEN=github_pat_REPLACE_WITH_YOUR_TOKEN

# --- Source-of-truth Google Doc IDs (the long id from each Doc's URL) --------
# Read by the n8n Google Docs nodes. Not secrets, but handy to keep here.
GOOGLE_DOC_ID_PRODUCT_MATRIX=1Jor2uhFHAeMaO4Q9Be9KAHBDfSfoCf7kHgMZRkE0f2M
GOOGLE_DOC_ID_CALL_SHEET=1TKD2yVT5v4uNtiAcejEacYQLEeHd4wAhDaTa3WM3TkE

# Note: Google access for the sync is configured as an OAuth2 credential inside n8n
# (an account/service-account with access to both Docs) — there is no API key to put here.
